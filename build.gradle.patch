// =============================================================================
// build.gradle snippets for a Forge 1.12.2 MDK
// =============================================================================
// The MDK ships with a build.gradle that has no libs/, no test setup, and
// placeholder project coordinates. Apply the three changes below.
//
// 1. Replace the placeholder project coordinates near the top of build.gradle:

version = '1.0'
group = 'com.flashminat0.selectivekeepinv'
archivesBaseName = 'selectivekeepinv'

// 2. Inside the existing `dependencies { ... }` block, add:

dependencies {
    compile fileTree(dir: 'libs', include: '*.jar')
    testCompile 'junit:junit:4.13.2'
}

// 3. At the BOTTOM of build.gradle, add:

test {
    testLogging {
        events 'passed', 'failed', 'skipped'
        showStandardStreams = true
        exceptionFormat = 'full'
    }
}

// =============================================================================
// The `libs/` folder should contain Baubles-1.12-1.5.2.jar and
// Trinkets and Baubles-0.32.5.jar so the *Compat classes can compile against
// their APIs. These are compile-only; they are NOT bundled into the output
// jar. At runtime the mod uses Loader.isModLoaded() to gate access, so it
// runs fine on servers without Baubles or Trinkets installed.
//
// Run tests + build:
//     ./gradlew test build        (macOS / Linux)
//     gradlew test build          (Windows)
//
// HTML test report:  build/reports/tests/test/index.html
// Built jar:         build/libs/selectivekeepinv-1.0.jar
// =============================================================================
